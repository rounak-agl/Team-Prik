# Copy to `.env` and fill in. .env is git-ignored — never commit real credentials.

# ── PostgreSQL (read-only live state: Trips, TripSeats, ReservedTickets, …) ──
# Either provide a full DSN:
POSTGRES_DSN=postgresql://USER:PASSWORD@HOST:5432/DBNAME
# …or the discrete parts (DSN takes precedence if both are set):
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_SSLMODE=require

# ── ClickHouse (historical reads + our new feature tables) ──
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=8443
CLICKHOUSE_DB=freshbus_operations
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_SECURE=true

# ── Staging admin API (to APPLY the two levers) ──
ADMIN_BASE_URL=https://api-stage.freshbus.com/admin
# Option A — paste a valid staging bearer token (e.g. Postman {{my_token}}):
ADMIN_TOKEN=
# Option B — admin email/password login (used if ADMIN_TOKEN is empty):
PORTAL_USER=
PORTAL_PASS=

# ── Gemini (optional — explanations) ──
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
